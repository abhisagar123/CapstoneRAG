# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Virtual environments (the local EDA venv is ~292MB — never commit)
.venv-eda/
.venv/
venv/
env/

# Secrets / API keys (OpenAI judge key wired in later, never committed)
.env
*.key
secrets.*

AI_CONTEXT.md

# Editor / OS
.idea/
.vscode/
.DS_Store

# Claude Code local session settings (machine-specific)
.claude/

# Large/derived data — cache locally, regenerate on demand
data/
*.faiss
*.index
# HuggingFace datasets cache, if ever placed in-repo
.cache/

# Notebook-generated SCRATCH artifacts that aren't deliverables (EDA dumps).
# NOTE: results/ragbench_matrix.csv IS a deliverable (the strategy×domain results
# matrix) — the broad `ragbench_*.csv` rule used to ignore it by accident, so it's
# un-ignored below. Keep new scratch dumps out of results/ (e.g. name them ragbench_scratch_*).
ragbench_schema.json
ragbench_*.csv
!results/ragbench_matrix.csv
# Any N-scaled matrix variant (ragbench_matrix_n50.csv, …) is also a deliverable — the
# broad rule above would ignore it. Keep scratch dumps named ragbench_scratch_* instead.
!results/ragbench_matrix_n*.csv
