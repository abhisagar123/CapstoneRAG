# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Virtual environments (the local EDA venv is ~292MB — never commit)
.venv-eda/
.venv/
venv/
env/

# Secrets / API keys (OpenAI judge key wired in later, never committed)
.env
*.key
secrets.*

AI_CONTEXT.md

# Editor / OS
.idea/
.vscode/
.DS_Store

# Claude Code local session settings (machine-specific)
.claude/

# Large/derived data — cache locally, regenerate on demand
data/
*.faiss
*.index
# HuggingFace datasets cache, if ever placed in-repo
.cache/

# Notebook-generated SCRATCH artifacts that aren't deliverables (EDA dumps).
# NOTE: the strategy×domain results matrices ARE deliverables — the broad `ragbench_*.csv`
# rule below would ignore them, so they're un-ignored. Keep scratch dumps named
# ragbench_scratch_* (those stay ignored).
ragbench_schema.json
ragbench_*.csv
# Un-ignore the matrix CSVs wherever they live under results/ — including the
# results/{per_example,pooled,validation}/ subdirs (added 13 Jun reorg). The `**` matches
# any depth, so a fresh run writing results/per_example/ragbench_matrix_n50.csv or
# results/pooled/ragbench_matrix_*.csv is tracked, not silently ignored.
!results/**/ragbench_matrix*.csv
!results/ragbench_matrix*.csv
